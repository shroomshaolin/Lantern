{
  "name": "lantern",
  "display_name": "Lantern",
  "version": "1.0.4",
  "description": "Support for reflection, clarity, calm, and next steps.",
  "author": "Donna",
  "capabilities": {
    "tools": [
      "tools/lantern.py"
    ],
    "routes": [
      {
        "method": "GET",
        "path": "personas",
        "handler": "routes/app_api.py:get_personas"
      },
      {
        "method": "GET",
        "path": "session/state",
        "handler": "routes/app_api.py:get_state"
      },
      {
        "method": "POST",
        "path": "session/start",
        "handler": "routes/app_api.py:start_session"
      },
      {
        "method": "POST",
        "path": "session/continue",
        "handler": "routes/app_api.py:continue_session"
      },
      {
        "method": "POST",
        "path": "session/user_message",
        "handler": "routes/app_api.py:user_message"
      },
      {
        "method": "POST",
        "path": "session/end",
        "handler": "routes/app_api.py:end_session"
      },
      {
