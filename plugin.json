        "path": "history/save",
        "handler": "routes/app_api.py:save_history"
      },
      {
        "method": "POST",
        "path": "history/load",
        "handler": "routes/app_api.py:load_history"
      },
      {
        "method": "POST",
        "path": "history/delete",
        "handler": "routes/app_api.py:delete_history"
      }
    ],
    "app": {
      "icon": "\ud83c\udfee"
    }
